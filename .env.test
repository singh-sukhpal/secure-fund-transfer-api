# define your env variables for the test env here
KERNEL_CLASS='App\Kernel'
APP_SECRET=test_secret_key
APP_ENV=test
APP_DEBUG=1
# DATABASE_URL="sqlite:///:memory:"
DATABASE_URL="sqlite:///%kernel.project_dir%/var/payseratest.db"

# Redis

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_CACHE_DB=1

# Lock configuration for tests
LOCK_DSN=redis://127.0.0.1:6379

# Messenger transport for tests
MESSENGER_TRANSPORT_DSN=redis://127.0.0.1:6379/messages

# Default URI for WebTestCase
DEFAULT_URI=http://localhost

# Rate limiter configuration
RATE_LIMITER_ENABLED=false

# Optional: Other missing env vars
MAILER_DSN=null://null
TRUSTED_HOSTS=localhost,127.0.0.1